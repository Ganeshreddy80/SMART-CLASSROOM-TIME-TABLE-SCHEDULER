# ──────────────────────────────────────────────────────────────
# UniSchedule — Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────────

# ── REQUIRED (app will crash on startup if missing) ───────────
FLASK_SECRET_KEY=change-this-to-a-long-random-string-min-16-chars
ADMIN_PASSWORD=change-this-to-a-strong-password-min-8-chars

# ── Database ──────────────────────────────────────────────────
# Supports: sqlite://, postgresql://, postgres://, mysql://
DATABASE_URL=sqlite:///university.db

# ── Flask Settings ────────────────────────────────────────────
FLASK_ENV=development          # 'development' or 'production'
FLASK_DEBUG=True                # True/False
FLASK_PORT=5000

# ── SMTP (optional — OTPs print to console if not set) ──────
SMTP_EMAIL=
SMTP_PASSWORD=

# ── OpenRouter AI (optional — chatbot disabled if not set) ──
OPENROUTER_API_KEY=

# ── Session / Security ──────────────────────────────────────
SESSION_LIFETIME=900            # seconds (default: 900 = 15 min)
PERMANENT_SESSION_LIFETIME=86400

# ── Attendance / GPS ─────────────────────────────────────────
GPS_MAX_DISTANCE=100            # metres
GPS_MAX_ACCURACY=50             # metres
QR_TOKEN_INTERVAL=3             # seconds
QR_TOKEN_GRACE=1                # extra grace seconds

# ── Timetable ─────────────────────────────────────────────────
MAX_CLASSES_PER_DAY=6
MAX_BACKTRACK_DEPTH=10
LUNCH_SLOT=12:00-1:00

# ── Admin / Defaults ────────────────────────────────────────
SMART_ADMIN_EMAIL=admin@srmap.edu.in
SMART_SESSION_LIFETIME_MINUTES=15
SMART_QR_INTERVAL=3

# ── Faculty / Student Defaults (optional) ───────────────────
DEFAULT_FACULTY_DESIGNATION=Assistant Professor
DEFAULT_FACULTY_SPECIALIZATION=Specialization
DEFAULT_FACULTY_PHONE=+91 00000 00000
DEFAULT_FACULTY_CABIN=Faculty Cabin
DEFAULT_FACULTY_JOINING_DATE=01 Jan 2020
DEFAULT_FACULTY_EXPERIENCE=5 years

# ── Student Defaults (optional) ─────────────────────────────
DEFAULT_STUDENT_PHONE=+91 00000 00000
DEFAULT_STUDENT_DOB=01 Jan 2005
DEFAULT_STUDENT_BLOOD=O+
DEFAULT_STUDENT_HOSTEL=Day Scholar
DEFAULT_STUDENT_ADVISOR=Faculty
DEFAULT_STUDENT_CGPA=8.5
DEFAULT_STUDENT_SEMESTER=4
DEFAULT_STUDENT_YEAR=2

# ── VPN Security (JSON list of CIDR ranges) ─────────────────
# VPN_RANGES=["104.16.0.0/12","172.64.0.0/13","162.158.0.0/15"]